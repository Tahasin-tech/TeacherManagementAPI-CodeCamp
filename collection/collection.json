        {
          "name": "Get All teachers",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "})\r",
                  "\r",
                  "pm.test(\"Schema Validation\", function () {\r",
                  "\r",
                  "    const responseJson = pm.response.json();\r",
                  "    pm.expect(responseJson).to.be.an(\"array\");\r",
                  "\r",
                  "const expectedSchema ={\r",
                  "\r",
                  "        \"_id\": \"string\",\r",
                  "        \"name\": \"string\",\r",
                  "        \"email\": \"string\",\r",
                  "        \"designation\": \"string\",\r",
                  "        \"teacherId\": \"number\",\r",
                  "        \"department\": \"string\"\r",
                  "\r",
                  "\r",
                  "}\r",
                  "responseJson.forEach((student,index) => {\r",
                  "        for (let key in expectedSchema) {\r",
                  "            pm.expect(student).to.have.property(key);\r",
                  "            pm.expect(typeof student[key]).to.equal(expectedSchema[key])\r",
                  "        }\r",
                  "})\r",
                  "\r",
                  "})\r",
                  "\r",
                  "let res = pm.response.json();\r",
                  "let createdTeacherId = pm.collectionVariables.get(\"teacher ID\");\r",
                  "\r",
                  "pm.test(\"Created teacher exists in list\", function () {\r",
                  "    let exists = res.some(function (teacher) {\r",
                  "        return teacher.teacherId == createdTeacherId ;\r",
                  "    });\r",
                  "\r",
                  "    pm.expect(exists).to.be.true;\r",
                  "});\r",
                  "\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
