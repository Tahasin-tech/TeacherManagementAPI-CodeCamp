          "name": "Login With wrong Credentials",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let jsonData= pm.response.json();\r",
                  "let token= jsonData.token;\r",
                  "pm.collectionVariables.set(\"token\",token)\r",
                  "\r",
                  "pm.test(\"login is unsuccessful\",()=>{\r",
                  "    pm.expect(jsonData.message).includes(\"Invalid credentials\")\r",
                  "})\r",
                  "\r",
