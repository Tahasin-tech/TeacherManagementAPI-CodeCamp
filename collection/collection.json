        {
          "name": "Create Teacher",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Teacher Created\", function(){\r",
                  "    pm.response.to.have.status(201);\r",
                  "})\r",
                  "\r",
                  "pm.test(\"ID exist in response\", function () {\r",
                  "\r",
                  "    let res = pm.response.json();\r",
                  "   \r",
                  "    pm.expect(res).to.have.property(\"_id\");\r",
                  "})\r",
                  "\r",
                  "\r",
                  "\r",
                  "\r",
                  "\r",
                  "let requestBody = JSON.parse(pm.request.body.raw);\r",
                  "let resBody = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Response matches request data\", function () {\r",
                  "    pm.expect(resBody.name).to.eql(requestBody.name);\r",
                  "    pm.expect(resBody.teacherId).to.eql(requestBody.teacherId);\r",
                  "    pm.expect(resBody.email).to.eql(requestBody.email);\r",
                  "    pm.expect(resBody.designation).to.eql(requestBody.designation);\r",
                  "    pm.expect(resBody.department).to.eql(requestBody.department);\r",
                  "   \r",
                  "});\r",
                  "\r",
                  "\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "let teacherId =Math.floor(Math.random()*10000);\r",
                  "pm.collectionVariables.set(\"teacher ID\", teacherId);\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \r\n        \"name\": \"Raf {{$randomFirstName}}\",\r\n        \"email\": \"{{$randomEmail}}\",\r\n        \"department\": \"CSE\",\r\n        \"teacherId\": {{teacher ID}},\r\n        \"designation\": \"Professor\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
